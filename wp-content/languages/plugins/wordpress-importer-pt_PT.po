#: class-wp-import.php:312
msgid "To make it simpler for you to edit and save the imported content, you may want to reassign the author of the imported item to an existing user of this site, such as your primary administrator account."
msgstr "Para ser mais fácil editar e guardar o conteúdo importado, pode atribuir a autoria do item importado a um utilizador existente no site, por exemplo, o administrador principal."

#: class-wp-import.php:1284
msgid "The uploaded file could not be moved"
msgstr "Não foi possível mover o ficheiro carregado"

#: class-wp-import.php:1269
msgid "Sorry, this file type is not permitted for security reasons."
msgstr "Desculpe, este tipo de ficheiro não é permitido por razões de segurança."

#: class-wp-import.php:1231
msgid "Downloaded file has incorrect size"
msgstr "O ficheiro descarregado tem um tamanho incorrecto"

#. translators: 1: The HTTP error message. 2: The HTTP error code.
#: class-wp-import.php:1207
msgid "Remote server returned the following unexpected result: %1$s (%2$s)"
msgstr "O servidor remoto devolveu o seguinte resultado inesperado: %1$s (%2$s)"

#. translators: 1: The WordPress error message. 2: The WordPress error code.
#: class-wp-import.php:1191
msgid "Request failed due to an error: %1$s (%2$s)"
msgstr "O pedido falhou devido a um erro: %1$s (%2$s)"

#: class-wp-import.php:1169
msgid "Could not create temporary file."
msgstr "Não foi possível criar ficheiro temporário."

