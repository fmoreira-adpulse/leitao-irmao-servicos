msgid "Zero size file downloaded"
msgstr "O ficheiro descarregado está vazio"

#: class-wp-import.php:351
msgid "Import author:"
msgstr "Importar autor:"

#: class-wp-import.php:219
msgid "All done."
msgstr "Concluído."

#: class-wp-import.php:219
msgid "Have fun!"
msgstr "Divirta-se!"

#: class-wp-import.php:1125
msgid "Invalid file type"
msgstr "Tipo de ficheiro inválido"

#: class-wp-import.php:1219
msgid "Remote server did not respond"
msgstr "O servidor remoto não respondeu"

#: class-wp-import.php:150 class-wp-import.php:161 class-wp-import.php:235
